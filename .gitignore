# Based on GitHub's Python and Windows gitignore templates,
# with additional Jupyter Notebook and JupyterLab exclusions.

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.hypothesis/
.pytest_cache/
cover/

# Environments
.env
.envrc
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Type checker / linter caches
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# Jupyter Notebook / Lab
*.ipynb
.ipynb_checkpoints/
.jupyter/
.jupyterlab-settings/
.jupyterlab-workspaces/

# IPython
profile_default/
ipython_config.py

# IDEs / editors
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.stackdump
*.lnk

# Local databases / logs
*.log
db.sqlite3
db.sqlite3-journal

# Misc
.python-version
cython_debug/
Dataframes/
